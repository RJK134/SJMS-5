# Shared Docker build context exclusions.
# Both api (server/Dockerfile) and client (client/Dockerfile) use root context.

# Local npm installs — Dockerfiles run npm ci fresh inside the image.
**/node_modules
**/.npm

# Build outputs — regenerated by the builder stage.
**/dist
**/build
**/.next
**/.vite

# Environment + secrets.
.env
.env.*
!.env.example

# Git + Claude metadata.
.git
.gitignore
.github
.claude
.cursor

# IDE / OS.
.vscode
.idea
.DS_Store
*.log
logs

# Docs + non-build artefacts.
docs
*.docx
*.pdf
backup-*.sql

# Docker config (prevent recursive context; Dockerfiles are COPY-ed explicitly).
docker-compose*.yml
docker/

# Prisma migrations (not needed at image build time).
prisma/migrations

# n8n workflows (runtime only).
n8n-workflows

# Test artefacts.
**/coverage
**/test-results
**/playwright-report
