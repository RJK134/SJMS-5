{
  "name": "05 — UKVI Compliance Monitor",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sjms/ukvi",
        "options": {}
      },
      "name": "SJMS Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.event }}",
              "value2": "ukvi.updated"
            }
          ]
        }
      },
      "name": "Filter Event",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "url": "=http://api:3001/api/v1/ukvi/{{ $json.data.id }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Service-Key",
              "value": "={{$env.INTERNAL_SERVICE_KEY}}"
            }
          ]
        },
        "options": {}
      },
      "name": "Get Details",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        650,
        200
      ]
    },
    {
      "parameters": {
        "url": "http://api:3001/api/v1/notifications",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Service-Key",
              "value": "={{$env.INTERNAL_SERVICE_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\"userId\":$json.data.studentId,\"title\":\"UKVI Compliance Monitor\",\"message\":\"UKVI record updated. Contact point review may be required.\",\"category\":\"UKVI\",\"priority\":\"HIGH\"}) }}",
        "options": {}
      },
      "name": "Create Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        850,
        200
      ]
    }
  ],
  "connections": {
    "SJMS Webhook": {
      "main": [
        [
          {
            "node": "Filter Event",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Filter Event": {
      "main": [
        [
          {
            "node": "Get Details",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Get Details": {
      "main": [
        [
          {
            "node": "Create Notification",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "sjms"
    }
  ]
}
