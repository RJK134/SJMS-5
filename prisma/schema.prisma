// DOMAIN 1 — IDENTITY & PERSON (17 models)
// ═══════════════════════════════════════════════════════════════════════════

model Person {
  id          String    @id @default(cuid())
  title       String?
  firstName   String    @map("first_name")
  middleNames String?   @map("middle_names")
  lastName    String    @map("last_name")
  dateOfBirth DateTime  @map("date_of_birth") @db.Date
  gender      Gender?
  legalSex    LegalSex? @map("legal_sex")
  pronouns    String?

  names               PersonName[]
  addresses           PersonAddress[]
  contacts            PersonContact[]
  identifiers         PersonIdentifier[]
  demographic         PersonDemographic?
  nationalities       PersonNationality[]
  photos              PersonPhoto[]
  nextOfKin           NextOfKin[]
  emergencyContacts   EmergencyContact[]
  student             Student?
  staff               Staff?
  applicant           Applicant?
  priorQualifications PriorQualification[]
  user                User?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("persons")
  @@index([lastName, firstName])
  @@index([dateOfBirth])
}

model PersonName {
  id        String   @id @default(cuid())
  personId  String   @map("person_id")
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  nameType  NameType @map("name_type")
  title     String?
  firstName String   @map("first_name")
  middleNames String? @map("middle_names")
  lastName  String   @map("last_name")
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("person_names")
  @@index([personId])
}

model PersonAddress {
  id          String      @id @default(cuid())
  personId    String      @map("person_id")
  person      Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  addressType AddressType @map("address_type")
  addressLine1 String     @map("address_line_1")
  addressLine2 String?    @map("address_line_2")
  addressLine3 String?    @map("address_line_3")
  city        String
  county      String?
  postcode    String?
  hesaPostcode String?    @map("hesa_postcode")
  countryCode String?     @map("country_code")
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime?   @map("end_date") @db.Date
  isPrimary   Boolean     @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("person_addresses")
  @@index([personId])
}

model PersonContact {
  id          String      @id @default(cuid())
  personId    String      @map("person_id")
  person      Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  contactType ContactType @map("contact_type")
  value       String
  isPrimary   Boolean     @default(false) @map("is_primary")
  isVerified  Boolean     @default(false) @map("is_verified")
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime?   @map("end_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("person_contacts")
  @@index([personId])
}

model PersonIdentifier {
  id             String         @id @default(cuid())
  personId       String         @map("person_id")
  person         Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  identifierType IdentifierType @map("identifier_type")
  value          String
  issuer         String?
  issueDate      DateTime?      @map("issue_date") @db.Date
  expiryDate     DateTime?      @map("expiry_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("person_identifiers")
  @@unique([identifierType, value])
  @@index([personId])
}

model PersonDemographic {
  id                String             @id @default(cuid())
  personId          String             @unique @map("person_id")
  person            Person             @relation(fields: [personId], references: [id], onDelete: Cascade)
  ethnicity         Ethnicity?
  disability        String?
  religion          Religion?
  sexualOrientation SexualOrientation? @map("sexual_orientation")
  careLeaver        Boolean?           @map("care_leaver")
  parentalEducation Boolean?           @map("parental_education")
  polarQuintile     Int?               @map("polar_quintile")
  imdQuintile       Int?               @map("imd_quintile")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("person_demographics")
}

model PersonNationality {
  id          String @id @default(cuid())
  personId    String @map("person_id")
  person      Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  countryCode String @map("country_code")
  isPrimary   Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("person_nationalities")
  @@index([personId])
}

model PersonPhoto {
  id       String @id @default(cuid())
  personId String @map("person_id")
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  filePath String @map("file_path")
  mimeType String @map("mime_type")
  fileSize Int    @map("file_size")
  isCurrent Boolean @default(true) @map("is_current")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("person_photos")
  @@index([personId])
}

model NextOfKin {
  id           String @id @default(cuid())
  personId     String @map("person_id")
