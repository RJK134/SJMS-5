model Assessment {
  id                 String         @id @default(cuid())
  moduleId           String         @map("module_id")
  module             Module         @relation(fields: [moduleId], references: [id])
  academicYear       String         @map("academic_year")
  title              String
  assessmentType     AssessmentType @map("assessment_type")
  weighting          Int
  maxMark            Decimal        @map("max_mark") @db.Decimal(6, 2)
  passMark           Decimal        @map("pass_mark") @db.Decimal(6, 2)
  dueDate            DateTime?      @map("due_date")
  submissionMethod   SubmissionMethod? @map("submission_method")
  isAnonymous        Boolean        @default(false) @map("is_anonymous")
  allowLateSubmission Boolean       @default(false) @map("allow_late_submission")
  latePolicy         Json?          @map("late_policy")

  attempts           AssessmentAttempt[]
  components         AssessmentComponent[]
  criteria           AssessmentCriteria[]
  extensions         AssessmentExtension[]
  submissions        Submission[]
  markingSchemes     MarkingScheme[]
  gradeBoundaries    GradeBoundary[]
