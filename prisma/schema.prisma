model Enrolment {
  id              String         @id @default(cuid())
  studentId       String         @map("student_id")
  student         Student        @relation(fields: [studentId], references: [id])
  programmeId     String         @map("programme_id")
  programme       Programme      @relation(fields: [programmeId], references: [id])
  academicYear    String         @map("academic_year")
  yearOfStudy     Int            @map("year_of_study")
  modeOfStudy     ModeOfStudy    @map("mode_of_study")
  startDate       DateTime       @map("start_date") @db.Date
  expectedEndDate DateTime?      @map("expected_end_date") @db.Date
  actualEndDate   DateTime?      @map("actual_end_date") @db.Date
  status          EnrolmentStatus @default(ENROLLED)
  feeStatus       FeeStatus      @map("fee_status")

  statusHistory       EnrolmentStatusHistory[]
  moduleRegistrations ModuleRegistration[]
  tasks               EnrolmentTask[]
  feeAssessments      FeeAssessment[]
  documents           EnrolmentDocument[]
  progressionRecords  ProgressionRecord[]
  awardRecords        AwardRecord[]
  placements          Placement[]
  interruptionRecords InterruptionRecord[]
  withdrawalRecords   WithdrawalRecord[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("enrolments")
  @@index([studentId])
  @@index([programmeId])
  @@index([academicYear])
  @@index([status])
}

model EnrolmentStatusHistory {
  id             String         @id @default(cuid())
  enrolmentId    String         @map("enrolment_id")
  enrolment      Enrolment      @relation(fields: [enrolmentId], references: [id], onDelete: Cascade)
  previousStatus EnrolmentStatus @map("previous_status")
  newStatus      EnrolmentStatus @map("new_status")
  changeDate     DateTime       @map("change_date")
  reason         String?        @db.Text
  changedBy      String?        @map("changed_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("enrolment_status_history")
  @@index([enrolmentId])
}

model ModuleRegistration {
  id               String          @id @default(cuid())
  enrolmentId      String          @map("enrolment_id")
