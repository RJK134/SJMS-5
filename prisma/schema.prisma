  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("hesa_modules")
  @@unique([moduleId, academicYear])
  @@index([academicYear])
}

model HESAStudentModule {
  id               String       @id @default(cuid())
  hesaStudentId    String       @map("hesa_student_id")
  hesaStudent      HESAStudent  @relation(fields: [hesaStudentId], references: [id])
  hesaModuleId     String       @map("hesa_module_id")
  hesaModule       HESAModule   @relation(fields: [hesaModuleId], references: [id])
  modOut           String?      @map("mod_out")
  modGrade         String?      @map("mod_grade")
  modMark          Decimal?     @map("mod_mark") @db.Decimal(6, 2)
  crdtAtmp         Int?         @map("crdt_atmp")
  crdtAchv         Int?         @map("crdt_achv")
  hesaData         Json?        @map("hesa_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("hesa_student_modules")
  @@unique([hesaStudentId, hesaModuleId])
  @@index([hesaModuleId])
}

model HESAEntryQualification {
  id               String   @id @default(cuid())
  studentId        String   @map("student_id")
