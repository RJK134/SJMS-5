  moduleRegistrationId  String             @map("module_registration_id")
  moduleRegistration    ModuleRegistration @relation(fields: [moduleRegistrationId], references: [id], onDelete: Restrict)
  attemptNumber         Int                @map("attempt_number") @default(1)
  rawMark               Decimal?           @map("raw_mark") @db.Decimal(6, 2)
  moderatedMark         Decimal?           @map("moderated_mark") @db.Decimal(6, 2)
  finalMark             Decimal?           @map("final_mark") @db.Decimal(6, 2)
  grade                 String?
  status                AttemptStatus      @default(PENDING)
  submittedDate         DateTime?          @map("submitted_date")
  markedDate            DateTime?          @map("marked_date")
  markedBy              String?            @map("marked_by")
  moderatedDate         DateTime?          @map("moderated_date")
