  programmeId  String       @map("programme_id")
  programme    Programme    @relation(fields: [programmeId], references: [id])
  academicYear String       @map("academic_year")
  husid        String?
  ukprn        String?      @default("10099999")
  courseId     String?      @map("course_id")
  comDate      DateTime?    @map("com_date") @db.Date
  endDate      DateTime?    @map("end_date") @db.Date
  rsnEnd       String?      @map("rsn_end")
  fundCode     String?      @map("fund_code")
  feeElig      String?      @map("fee_elig")
  mstuFee      String?      @map("mstu_fee")
  loSession    String?      @map("lo_session")
  typeYr       HESAYearType? @map("type_yr")
  mode         String?

  createdAt DateTime @default(now()) @map("created_at")
