generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime connection — point at the Neon pooled (PGBouncer) endpoint in
  // production so Vercel's auto-scaling does not exhaust connection slots.
  url      = env("DATABASE_URL")
  // Migration connection — when `DIRECT_URL` is set, `prisma migrate deploy`
  // and `prisma db push` route through the unpooled endpoint instead. This
  // avoids PGBouncer transaction-mode prepared-statement collisions that
  // otherwise abort the deploy-init step on first deploy and leave the
  // database un-migrated (and therefore un-seeded). Unset locally is fine —
  // Prisma falls back to `url`. See docs/VERCEL-RUNBOOK.md §4.2.
  directUrl = env("DIRECT_URL")
}

