  qualType         String   @map("qual_type")
  qualEnt3         String?  @map("qual_ent3")
  qualCls2         String?  @map("qual_cls2")
  qualSbj1         String?  @map("qual_sbj1")
  qualSbj2         String?  @map("qual_sbj2")
  qualSbj3         String?  @map("qual_sbj3")
  qualGrade        String?  @map("qual_grade")
  qualYear         Int?     @map("qual_year")
  institution      String?
  country          String?
  tariffPoints     Int?     @map("tariff_points")
  hesaData         Json?    @map("hesa_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("hesa_entry_qualifications")
  @@index([studentId])
}

model StudentCourseSession {
  id           String       @id @default(cuid())
