model StudentAccount {
  id           String  @id @default(cuid())
  studentId    String  @map("student_id")
  student      Student @relation(fields: [studentId], references: [id])
  academicYear String  @map("academic_year")
  balance              Decimal @default(0) @db.Decimal(10, 2)
  creditLimit          Decimal @default(0) @map("credit_limit") @db.Decimal(10, 2)
  status               String  @default("active")
  totalDebits          Decimal @default(0) @map("total_debits") @db.Decimal(10, 2)
  totalCredits         Decimal @default(0) @map("total_credits") @db.Decimal(10, 2)
  lastTransactionDate  DateTime? @map("last_transaction_date")
  reconciliationStatus ReconciliationStatus @default(BALANCED) @map("reconciliation_status")
  lastReconciledDate   DateTime? @map("last_reconciled_date")
  lastReconciledBy     String?   @map("last_reconciled_by")

  chargeLines            ChargeLine[]
  invoices               Invoice[]
  payments               Payment[]
  financialTransactions  FinancialTransaction[]
  paymentPlans      PaymentPlan[]
  sponsorAgreements SponsorAgreement[]
  refundApprovals   RefundApproval[]
  debtActions       DebtAction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("student_accounts")
  @@index([studentId])
  @@index([academicYear])
}

model ChargeLine {
  id               String        @id @default(cuid())
  studentAccountId String        @map("student_account_id")
  studentAccount   StudentAccount @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  chargeType       ChargeType    @map("charge_type")
  description      String
  amount           Decimal       @db.Decimal(10, 2)
  /// Running total of amounts applied by completed payment allocations against this line.
  /// Used by the payment-allocation pipeline (Phase 18C+) so that partial allocations are
  /// carried forward correctly and each run uses `outstanding = amount − paidAmount` rather
  /// than the full original amount.
  paidAmount       Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  currency         String        @default("GBP")
  taxCode          String?       @map("tax_code")
  invoiceId        String?       @map("invoice_id")
  invoice          Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  status           ChargeStatus  @default(PENDING)
  dueDate          DateTime?     @map("due_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("charge_lines")
  @@index([studentAccountId])
  @@index([invoiceId])
}

model Invoice {
  id               String         @id @default(cuid())
  studentAccountId String         @map("student_account_id")
  studentAccount   StudentAccount @relation(fields: [studentAccountId], references: [id])
  invoiceNumber    String         @unique @map("invoice_number")
  issueDate        DateTime       @map("issue_date") @db.Date
  dueDate          DateTime       @map("due_date") @db.Date
  totalAmount      Decimal        @map("total_amount") @db.Decimal(10, 2)
  paidAmount       Decimal        @default(0) @map("paid_amount") @db.Decimal(10, 2)
  status           InvoiceStatus  @default(DRAFT)
  sentDate         DateTime?      @map("sent_date")

  chargeLines ChargeLine[]
  payments    Payment[]
  creditNotes CreditNote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("invoices")
  @@index([studentAccountId])
}

model Payment {
  id               String         @id @default(cuid())
  studentAccountId String         @map("student_account_id")
  studentAccount   StudentAccount @relation(fields: [studentAccountId], references: [id])
  invoiceId        String?        @map("invoice_id")
  invoice          Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amount           Decimal        @db.Decimal(10, 2)
  paymentMethod    PaymentMethod  @map("payment_method")
  reference        String?
  transactionDate  DateTime       @map("transaction_date")
  status           PaymentStatus  @default(PENDING)
  /// Timestamp set by the payment-allocation pipeline after a successful
  /// persist run.  Acts as an idempotency marker so a payment cannot be
  /// double-applied to the ledger without an explicit force flag.
  allocatedAt      DateTime?      @map("allocated_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("payments")
  @@index([studentAccountId])
  @@index([invoiceId])
}

model PaymentPlan {
  id                  String            @id @default(cuid())
  studentAccountId    String            @map("student_account_id")
  studentAccount      StudentAccount    @relation(fields: [studentAccountId], references: [id])
  planType            String            @map("plan_type")
  totalAmount         Decimal           @map("total_amount") @db.Decimal(10, 2)
  numberOfInstalments Int               @map("number_of_instalments")
  instalmentAmount    Decimal           @map("instalment_amount") @db.Decimal(10, 2)
  startDate           DateTime          @map("start_date") @db.Date
  status              PaymentPlanStatus @default(ACTIVE)

  instalments PaymentInstalment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("payment_plans")
  @@index([studentAccountId])
}

model PaymentInstalment {
  id            String      @id @default(cuid())
  paymentPlanId String      @map("payment_plan_id")
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
  instalmentNum Int         @map("instalment_num")
  amount        Decimal     @db.Decimal(10, 2)
  dueDate       DateTime    @map("due_date") @db.Date
  paidDate      DateTime?   @map("paid_date")
  status        PaymentStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("payment_instalments")
  @@index([paymentPlanId])
}

model SponsorAgreement {
