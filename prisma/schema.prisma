model SecondMarkingRecord {
  id             String     @id @default(cuid())
  assessmentId   String     @map("assessment_id")
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  studentId      String     @map("student_id")
  firstMarkerMark  Decimal  @map("first_marker_mark") @db.Decimal(6, 2)
  secondMarkerMark Decimal  @map("second_marker_mark") @db.Decimal(6, 2)
  agreedMark     Decimal?   @map("agreed_mark") @db.Decimal(6, 2)
  secondMarkerId String     @map("second_marker_id")
  completedDate  DateTime?  @map("completed_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("second_marking_records")
  @@index([assessmentId])
}

model AssessmentComponent {
  id             String         @id @default(cuid())
  assessmentId   String         @map("assessment_id")
  assessment     Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Restrict)
  title          String
  componentType  AssessmentType @map("component_type")
  weighting      Int
  maxMark        Decimal        @map("max_mark") @db.Decimal(6, 2)
  passMark       Decimal?       @map("pass_mark") @db.Decimal(6, 2)
  sortOrder      Int            @default(0) @map("sort_order")

  markEntries    MarkEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("assessment_components")
  @@index([assessmentId])
}

/// Append-only mark record: each stage transition creates a NEW row.
/// This provides a full audit trail of the 7-stage marks pipeline.
model MarkEntry {
  id                   String              @id @default(cuid())
  assessmentComponentId String             @map("assessment_component_id")
  assessmentComponent  AssessmentComponent @relation(fields: [assessmentComponentId], references: [id], onDelete: Restrict)
  moduleRegistrationId String             @map("module_registration_id")
  moduleRegistration   ModuleRegistration @relation(fields: [moduleRegistrationId], references: [id], onDelete: Restrict)
  attemptNumber        Int                @map("attempt_number") @default(1)
  stage                MarkStage
  mark                 Decimal?           @db.Decimal(6, 2)
  grade                String?
  markerId             String?            @map("marker_id")
  markerName           String?            @map("marker_name")
  feedback             String?            @db.Text
  markedAt             DateTime           @map("marked_at")

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  deletedAt DateTime? @map("deleted_at")

  @@map("mark_entries")
  @@index([assessmentComponentId])
  @@index([moduleRegistrationId])
  @@index([stage])
}

