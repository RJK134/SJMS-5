  @@index([programmeId])
  @@index([academicYearId])
}

model StatutoryReturnRun {
  id               String           @id @default(cuid())
  returnType       StatReturnType   @map("return_type")
  academicYear     String           @map("academic_year")
  runNumber        Int              @map("run_number")
  status           HESAReturnStatus @default(PREPARATION)
  validationErrors Json?            @map("validation_errors")
  recordCount      Int              @default(0) @map("record_count")
  errorCount       Int              @default(0) @map("error_count")
  warningCount     Int              @default(0) @map("warning_count")
  submittedBy      String?          @map("submitted_by")
  submittedDate    DateTime?        @map("submitted_date")
  acknowledgedDate DateTime?        @map("acknowledged_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("statutory_return_runs")
  @@index([returnType, academicYear])
}

model FinancialTransaction {
  id                      String           @id @default(cuid())
  transactionRef          String           @unique @map("transaction_ref")
  studentAccountId        String           @map("student_account_id")
  studentAccount          StudentAccount   @relation(fields: [studentAccountId], references: [id])
  transactionType         FinTxnType       @map("transaction_type")
  debitAmount             Decimal          @default(0) @map("debit_amount") @db.Decimal(10, 2)
  creditAmount            Decimal          @default(0) @map("credit_amount") @db.Decimal(10, 2)
  runningBalance          Decimal          @map("running_balance") @db.Decimal(10, 2)
  reference               String?
  description             String
  relatedEntityType       String?          @map("related_entity_type")
  relatedEntityId         String?          @map("related_entity_id")
  postedDate              DateTime         @map("posted_date")
  effectiveDate           DateTime         @map("effective_date") @db.Date
  financialPeriodId       String?          @map("financial_period_id")
  financialPeriod         FinancialPeriod? @relation(fields: [financialPeriodId], references: [id])
  reversedByTransactionId String?          @unique @map("reversed_by_transaction_id")
  reversedByTransaction   FinancialTransaction? @relation("TxnReversal", fields: [reversedByTransactionId], references: [id])
  reversesTransaction     FinancialTransaction? @relation("TxnReversal")
  status                  FinTxnStatus     @default(POSTED)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("financial_transactions")
  @@index([studentAccountId])
  @@index([postedDate])
  @@index([financialPeriodId])
}

model FinancialPeriod {
  id         String          @id @default(cuid())
  periodCode String          @unique @map("period_code")
  startDate  DateTime        @map("start_date") @db.Date
  endDate    DateTime        @map("end_date") @db.Date
  status     FinPeriodStatus @default(OPEN)
  closedBy   String?         @map("closed_by")
  closedDate DateTime?       @map("closed_date")

  transactions FinancialTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("financial_periods")
}

model DataClassification {
  id                 String         @id @default(cuid())
  modelName          String         @map("model_name")
  fieldName          String         @map("field_name")
  classification     DataClassLevel
  gdprBasis          GdprBasis?     @map("gdpr_basis")
  retentionPeriod    Int?           @map("retention_period")
  encryptionRequired Boolean        @default(false) @map("encryption_required")
  accessRoles        Json?          @map("access_roles")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")

  @@map("data_classifications")
  @@unique([modelName, fieldName])
}
